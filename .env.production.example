# Docker host and TLS
DOMAIN=legal.example.com
ACME_EMAIL=admin@example.com
HTTP_PORT=80
HTTPS_PORT=443

# Service images. CI overrides these with immutable Git SHA tags.
VLEGAL_API_IMAGE=vlegal-api:latest
VLEGAL_FRONTEND_IMAGE=vlegal-frontend:latest
VLEGAL_WORKER_IMAGE=vlegal-worker:latest
VLEGAL_BEAT_IMAGE=vlegal-beat:latest
VLEGAL_MIGRATE_IMAGE=vlegal-migrate:latest
VLEGAL_MODEL_INIT_IMAGE=vlegal-model-init:latest
VLEGAL_REINDEX_IMAGE=vlegal-reindex:latest

# Legal corpus on the Docker host. Use an absolute path in production.
LEGAL_DATA_HOST_PATH=/opt/vlegal/legal-data

# Docker-managed data services. Generate URL-safe values, for example:
# openssl rand -hex 32
POSTGRES_DB=vlegal
POSTGRES_USER=vlegal
POSTGRES_PASSWORD=change-me-postgres
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G

# Application
APP_ENV=production
LOG_LEVEL=INFO
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_SECONDS=28800
MESSAGE_ENCRYPTION_KEY=replace-with-32-url-safe-base64-bytes
GUEST_CHAT_REQUESTS_PER_MINUTE=4
GUEST_CHAT_REQUESTS_PER_HOUR=30
CONVERSATION_SUMMARY_BATCH_SIZE=12
CONVERSATION_SUMMARY_MAX_TOKENS=900
SEMANTIC_ANSWER_CACHE_ENABLED=true
SEMANTIC_ANSWER_CACHE_SIMILARITY=0.96
SEMANTIC_ANSWER_CACHE_TTL_HOURS=24
SEMANTIC_ANSWER_CACHE_MAX_QUERY_CHARS=1500

# Google OAuth/OIDC
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
OIDC_CLIENT_SECRET=your-google-web-client-secret
OIDC_SCOPES=openid email profile
OIDC_ADMIN_GROUPS=vlegal-admins
OIDC_REVIEWER_GROUPS=vlegal-reviewers

# Retrieval and legal freshness
RETRIEVER_BACKEND=hybrid_rag
RETRIEVAL_TOP_K=10
LEGAL_FRESHNESS_TTL_HOURS=24
LEGAL_VERIFICATION_CONCURRENCY=4
FRESHNESS_LOCK_WAIT_SECONDS=120
REQUIRE_FRESHNESS_CHECK=true
MAX_LAWS_VERIFIED_PER_REQUEST=16
TAVILY_API_KEY=your-tavily-api-key
TAVILY_SEARCH_DEPTH=advanced
TAVILY_TIMEOUT_SECONDS=30
OFFICIAL_LEGAL_DOMAINS=vanban.chinhphu.vn,vbpl.vn,quochoi.vn,congbao.chinhphu.vn,moj.gov.vn

# Qwen model. model-init downloads it once into a Docker named volume.
QWEN_MODEL_REPO=Qwen/Qwen3-14B
QWEN_MODEL_REVISION=main
# Optional for private/gated Hugging Face repositories.
HF_TOKEN=
QWEN_MODEL=Qwen3-14B
QWEN_DEVICE=auto
QWEN_DTYPE=auto
QWEN_MAX_INPUT_TOKENS=24576
QWEN_MAX_NEW_TOKENS=5120
QWEN_MAX_CONCURRENT_GENERATIONS=1
QWEN_TOP_P=0.9
QWEN_TRUST_REMOTE_CODE=false

# BGE-M3 semantic embeddings, loaded only from the local checkpoint at runtime.
EMBEDDING_MODEL_REPO=BAAI/bge-m3
EMBEDDING_MODEL_REVISION=main
EMBEDDING_MODEL_PATH=/models/embedding
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=4
EMBEDDING_MAX_SEQUENCE_LENGTH=2048

# Graph/vector stores: Neo4j + PostgreSQL pgvector
NEO4J_DATABASE=neo4j
POSTGRES_VECTOR_SIZE=1024
