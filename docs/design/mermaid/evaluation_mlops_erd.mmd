erDiagram
    DATASET_VERSION {
        uuid dataset_version_id PK
        string dataset_name
        string version_name
        string purpose
        string source_manifest_uri
        string source_manifest_hash
        string preprocessing_config_hash
        int split_seed
        string label_schema_version
        string dataset_status
        datetime created_at
    }

    DATA_SPLIT {
        uuid split_id PK
        uuid dataset_version_id FK
        string split_name
        bool is_frozen
        int case_count
        string manifest_hash
    }

    EVAL_CASE {
        uuid eval_case_id PK
        uuid split_id FK
        string external_key
        text question
        text reference_answer
        string category
        string difficulty
        string annotation_status
    }

    GROUND_TRUTH_EVIDENCE {
        uuid ground_truth_id PK
        uuid eval_case_id FK
        uuid document_version_id FK
        uuid chunk_id FK
        string legal_citation
        int relevance_grade
        int span_start
        int span_end
    }

    ANNOTATION_REVIEW {
        uuid annotation_review_id PK
        uuid eval_case_id FK
        uuid reviewer_user_id FK
        string review_decision
        text review_notes
        datetime reviewed_at
    }

    EXPERIMENT {
        uuid experiment_id PK
        string experiment_name
        text objective
        string owner_reference
        datetime created_at
    }

    PROMPT_VERSION {
        uuid prompt_version_id PK
        string prompt_name
        string version_name
        string template_hash
        string template_uri
        datetime created_at
    }

    MODEL_VERSION {
        uuid model_version_id PK
        string provider
        string model_name
        string parameter_scale
        string revision
        string model_role
        string artifact_uri
        string model_checksum
        datetime registered_at
    }

    EXPERIMENT_RUN {
        uuid run_id PK
        uuid experiment_id FK
        uuid dataset_version_id FK
        uuid index_version_id FK
        uuid prompt_version_id FK
        string retrieval_mode
        string git_sha
        string config_hash
        string environment_hash
        int random_seed
        bool is_baseline
        string run_status
        datetime started_at
        datetime finished_at
    }

    RUN_MODEL_BINDING {
        uuid run_model_binding_id PK
        uuid run_id FK
        uuid model_version_id FK
        string model_role
    }

    CASE_RESULT {
        uuid case_result_id PK
        uuid run_id FK
        uuid eval_case_id FK
        text generated_answer
        string result_status
        int latency_ms
        int input_tokens
        int output_tokens
    }

    CASE_RETRIEVAL {
        uuid case_retrieval_id PK
        uuid case_result_id FK
        uuid chunk_id FK
        int rank_no
        decimal retrieval_score
        bool is_ground_truth
        string retrieval_reason
    }

    METRIC_DEFINITION {
        uuid metric_id PK
        string metric_code UK
        string metric_level
        string direction
        string formula_version
        uuid evaluator_model_id FK
    }

    METRIC_OBSERVATION {
        uuid observation_id PK
        uuid metric_id FK
        uuid run_id FK
        uuid case_result_id FK
        string observation_scope
        decimal metric_value
        int sample_count
        datetime measured_at
    }

    ERROR_CASE {
        uuid error_case_id PK
        uuid case_result_id FK
        string error_category
        string severity
        text observed_behavior
        text expected_behavior
        text root_cause
        text remediation
        string analysis_status
        datetime created_at
    }

    RUN_COMPARISON {
        uuid comparison_id PK
        uuid baseline_run_id FK
        uuid candidate_run_id FK
        uuid metric_id FK
        decimal baseline_value
        decimal candidate_value
        decimal delta_value
        decimal significance_value
        string decision
    }

    RUN_ARTIFACT {
        uuid artifact_id PK
        uuid run_id FK
        string artifact_type
        string artifact_uri
        string artifact_checksum
        datetime created_at
    }

    DATASET_VERSION ||--|{ DATA_SPLIT : partitions
    DATA_SPLIT ||--o{ EVAL_CASE : contains
    EVAL_CASE ||--o{ GROUND_TRUTH_EVIDENCE : expects
    EVAL_CASE ||--o{ ANNOTATION_REVIEW : verified_by

    EXPERIMENT ||--|{ EXPERIMENT_RUN : executes
    DATASET_VERSION ||--o{ EXPERIMENT_RUN : evaluates_on
    PROMPT_VERSION o|--o{ EXPERIMENT_RUN : uses

    EXPERIMENT_RUN ||--o{ RUN_MODEL_BINDING : binds
    MODEL_VERSION ||--o{ RUN_MODEL_BINDING : selected_as

    EXPERIMENT_RUN ||--o{ CASE_RESULT : produces
    EVAL_CASE ||--o{ CASE_RESULT : evaluated_as
    CASE_RESULT ||--o{ CASE_RETRIEVAL : retrieves

    METRIC_DEFINITION ||--o{ METRIC_OBSERVATION : defines
    EXPERIMENT_RUN ||--o{ METRIC_OBSERVATION : aggregates
    CASE_RESULT o|--o{ METRIC_OBSERVATION : details

    CASE_RESULT ||--o{ ERROR_CASE : analyzed_as
    EXPERIMENT_RUN ||--o{ RUN_ARTIFACT : emits

    EXPERIMENT_RUN ||--o{ RUN_COMPARISON : baseline
    EXPERIMENT_RUN ||--o{ RUN_COMPARISON : candidate
    METRIC_DEFINITION ||--o{ RUN_COMPARISON : compares_by
