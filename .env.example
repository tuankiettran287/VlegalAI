# Application
APP_ENV=development
PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
LOG_LEVEL=INFO

# PostgreSQL (use Amazon RDS/Aurora PostgreSQL in production)
DATABASE_URL=postgresql+asyncpg://vlegal:vlegal@postgres:5432/vlegal
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
REDIS_URL=redis://redis:6379/0

# Google Account login (Gmail and Google Workspace) using OAuth 2.0 / OIDC.
# Create a Web application OAuth client in Google Cloud Console and register
# OIDC_REDIRECT_URI as an Authorized redirect URI.
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_SECONDS=28800
COOKIE_SECURE=false
GUEST_CHAT_REQUESTS_PER_MINUTE=4
GUEST_CHAT_REQUESTS_PER_HOUR=30
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
OIDC_CLIENT_SECRET=your-google-web-client-secret
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
OIDC_SCOPES=openid email profile
OIDC_ADMIN_GROUPS=vlegal-admins
OIDC_REVIEWER_GROUPS=vlegal-reviewers

# 32 random bytes encoded with URL-safe base64. Production must use a
# dedicated value from AWS Secrets Manager.
MESSAGE_ENCRYPTION_KEY=

# Server-only policy; intentionally hidden from the frontend.
RETRIEVER_BACKEND=hybrid_rag
RETRIEVAL_TOP_K=10
LEGAL_FRESHNESS_TTL_HOURS=24
LEGAL_VERIFICATION_CONCURRENCY=4
FRESHNESS_LOCK_TTL_SECONDS=120
REQUIRE_FRESHNESS_CHECK=true
MAX_LAWS_VERIFIED_PER_REQUEST=16

# Qwen3 offline. Download/copy the complete checkpoint beforehand; the
# application uses local_files_only=True and never calls a model API.
QWEN_MODEL_PATH=models/Qwen3-4B
QWEN_MODEL=Qwen3-4B
QWEN_DEVICE=auto
QWEN_DTYPE=auto
QWEN_MAX_INPUT_TOKENS=24576
QWEN_MAX_NEW_TOKENS=5120
QWEN_MAX_CONCURRENT_GENERATIONS=1
QWEN_TOP_P=0.9
QWEN_TRUST_REMOTE_CODE=false

# Called before every legal result to verify cited laws are still current
TAVILY_API_KEY=your-tavily-api-key
TAVILY_SEARCH_DEPTH=advanced
TAVILY_TIMEOUT_SECONDS=30
OFFICIAL_LEGAL_DOMAINS=vanban.chinhphu.vn,vbpl.vn,quochoi.vn,congbao.chinhphu.vn,moj.gov.vn

# Neo4j Aura + Qdrant Cloud in production, local containers in development
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-neo4j-password
NEO4J_DATABASE=neo4j
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=local-qdrant-key
QDRANT_COLLECTION=vlegal_legal_chunks
QDRANT_VECTOR_NAME=abstract-dense-vector
QDRANT_VECTOR_SIZE=1536

# Existing local corpus/staging paths (optional)
LEGAL_DATA_DIR=Data (1)
LEGAL_STORAGE_DIR=storage/graphrag
LEGAL_GRAPHRAG_DB=storage/graphrag/legal_graphrag.sqlite

# AWS and workers
AWS_REGION=ap-southeast-1
S3_BUCKET=
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
