# Application
APP_ENV=development
PUBLIC_URL=https://vlegal-api-201653369723.asia-southeast1.run.app
FRONTEND_URL=https://vlegal-frontend-201653369723.asia-southeast1.run.app
CORS_ORIGINS=["*"]
COOKIE_SECURE=true

# Neon PostgreSQL Database (Production)
DATABASE_URL=postgresql+asyncpg://user:password@ep-your-db.neon.tech/neondb?sslmode=require
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Gemini AI Credentials & Model
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-pro

# Google Account login (OAuth 2.0 / OIDC)
OIDC_CLIENT_ID=YOUR_GOOGLE_OIDC_CLIENT_ID.apps.googleusercontent.com
OIDC_CLIENT_SECRET=YOUR_GOOGLE_OIDC_CLIENT_SECRET
OIDC_REDIRECT_URI=https://vlegal-api-201653369723.asia-southeast1.run.app/api/auth/google/callback

# Retrieval & Model Settings
RETRIEVER_BACKEND=postgres
POSTGRES_VECTOR_SIZE=1024
EMBEDDING_MODEL_PATH=models/bge-m3
EMBEDDING_MODEL_REPO=BAAI/bge-m3
EMBEDDING_MODEL_REVISION=main
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_SEQUENCE_LENGTH=2048

# Answer Cache & Limits
CONVERSATION_SUMMARY_BATCH_SIZE=12
CONVERSATION_SUMMARY_MAX_TOKENS=900
SEMANTIC_ANSWER_CACHE_ENABLED=true
SEMANTIC_ANSWER_CACHE_SIMILARITY=0.96
SEMANTIC_ANSWER_CACHE_TTL_HOURS=24
SEMANTIC_ANSWER_CACHE_MAX_QUERY_CHARS=1500
