GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional staging paths
LEGAL_DATA_DIR=F:\VlegalAI\Data (1)
LEGAL_STORAGE_DIR=F:\VlegalAI\storage\graphrag
LEGAL_GRAPHRAG_DB=F:\VlegalAI\storage\graphrag\legal_graphrag.sqlite

# Runtime search mode: rag, graphrag, hybrid_rag
# Backward-compatible backend values: auto, qdrant, neo4j, hybrid
RETRIEVER_BACKEND=hybrid_rag

# Neo4j local, no Docker required if you install Neo4j Desktop or Neo4j service.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# Qdrant Cloud collection shown in your screenshot.
QDRANT_URL=https://your-cluster-url.qdrant.tech
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=laborcare_legal_chunks
QDRANT_VECTOR_NAME=abstract-dense-vector
QDRANT_VECTOR_SIZE=1536
EXTERNAL_SYNC_BATCH_SIZE=256

# RAGAS notebook evaluation
RAGAS_EVAL_DATASET=F:\VlegalAI\eval_legal_rag_graphrag_1000.json
RAGAS_EVAL_OUT_DIR=F:\VlegalAI\storage\eval\ragas_notebook
RAGAS_EVAL_BACKENDS=rag graphrag
RAGAS_EVAL_TOP_K=10
RAGAS_EVAL_OFFSET=0
RAGAS_EVAL_LIMIT=20
RAGAS_RESPONSE_MODE=generate
RAGAS_RUN=true
RAGAS_EVALUATOR_PROVIDER=groq
RAGAS_EVALUATOR_MODEL=
RAGAS_EMBEDDING_PROVIDER=legal_hash
RAGAS_EMBEDDING_MODEL=
RAGAS_METRICS=context_precision context_recall faithfulness answer_relevancy answer_correctness
RAGAS_BATCH_SIZE=4
RAGAS_RAISE_EXCEPTIONS=false

# Optional, only needed when ngrok requires account auth.
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
