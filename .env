APP_ENV=development

# PostgreSQL 18 / pgvector on GCP through Cloud SQL Auth Proxy with IAM auth.
GOOGLE_CLOUD_PROJECT=project-2c74565e-9f12-4b62-a4e
CLOUD_SQL_INSTANCE_CONNECTION_NAME=project-2c74565e-9f12-4b62-a4e:asia-east2:vlegalai
DATABASE_URL=postgresql+asyncpg://trantuankieta6%40gmail.com@127.0.0.1:5433/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# PostgreSQL/pgvector is the only retrieval database.
RETRIEVER_BACKEND=postgres
POSTGRES_VECTOR_SIZE=1024
EXTERNAL_SYNC_BATCH_SIZE=256
HYBRID_VECTOR_WEIGHT=0.55
HYBRID_BM25_WEIGHT=0.45
HYBRID_RRF_K=60
BM25_K1=1.5
BM25_B=0.75

# Legal corpus and temporary local build artifact.
LEGAL_DATA_DIR=Data (1)
LEGAL_STORAGE_DIR=storage/graphrag
LEGAL_GRAPHRAG_DB=storage/graphrag/legal_graphrag.sqlite

# Local BGE-M3 embedding runtime.
EMBEDDING_MODEL_PATH=models/bge-m3
EMBEDDING_MODEL_REPO=BAAI/bge-m3
EMBEDDING_MODEL_REVISION=main
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_SEQUENCE_LENGTH=2048

# GCP Memorystore/Redis is used only for cache, rate limiting, and task transport.
REDIS_URL=rediss://10.170.0.3:6379/0
REDIS_CLUSTER_MODE=true
REDIS_IAM_AUTH=true
REDIS_CA_CERTS=server-ca.pem
CELERY_BROKER_URL=gcpubsub://projects/project-2c74565e-9f12-4b62-a4e
