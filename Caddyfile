{
	email {$ACME_EMAIL}
	admin off
}

{$DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		-Server
	}

	reverse_proxy api:8000 {
		health_uri /api/health/live
		health_interval 30s
		health_timeout 5s
	}

	log {
		output stdout
		format json
	}
}
