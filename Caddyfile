{
	email {$ACME_EMAIL}
	admin off
}

{$DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		-Server
	}

	@api path /api/*
	reverse_proxy @api api:8080 {
		health_uri /api/health/live
		health_interval 30s
		health_timeout 5s
	}

	reverse_proxy frontend:8080

	log {
		output stdout
		format json
	}
}
