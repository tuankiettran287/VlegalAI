aws_region         = "ap-southeast-1"
name               = "vlegal-prod"
vpc_id             = "vpc-xxxxxxxx"
public_subnet_ids  = ["subnet-public-a", "subnet-public-b"]
private_subnet_ids = ["subnet-private-a", "subnet-private-b"]
certificate_arn    = "arn:aws:acm:ap-southeast-1:123456789012:certificate/xxxxxxxx"
public_url         = "https://legal.example.com"

oidc_issuer        = "https://accounts.google.com"
oidc_client_id     = "replace-me.apps.googleusercontent.com"
oidc_client_secret = "replace-google-oauth-client-secret"

qwen_api_key  = "replace-me"
tavily_api_key = "replace-me"
neo4j_uri      = "neo4j+s://your-aura-instance.databases.neo4j.io"
neo4j_user     = "neo4j"
neo4j_password = "replace-me"
qdrant_url     = "https://your-cluster.qdrant.io"
qdrant_api_key = "replace-me"
